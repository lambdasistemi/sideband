# EXAMPLE mux backend — annotated skeleton for supporting a non-tmux
# multiplexer. Read mux-backends/README.md for the full contract; this file is
# the copy-paste starting point.
#
# Copy this file to mux-backends/<yourmux> (e.g. zellij, screen, wezterm),
# implement the four functions for your multiplexer, then select it with
#   export SIDEBAND_MUX=<yourmux>
# before running `go-mobile`. (SIDEBAND_MUX may also be an absolute path to a
# backend file kept outside this repo.) Verify it with:
#   SIDEBAND_MUX=<yourmux> ../mux-selftest
#
# A "handle" is whatever opaque string your backend uses to address one pane
# (a pane id, a tab name, a session:window.pane triple). mux passes handles
# back to you verbatim; only your backend interprets them.
#
# Sketches below show the closest zellij / screen commands. They are NOT
# verified against every version — treat them as a starting point and run
# mux-selftest on your setup before relying on the liaison.

# Print an opaque handle for the CURRENT pane. Callers store it and later pass
# it to inject/focus. Must be stable for the pane's lifetime.
mux_self() {
    # zellij: printf '%s\n' "${ZELLIJ_PANE_ID:?set a pane name and echo it}"
    # screen: printf '%s\n' "${STY:?}:${WINDOW:?}"
    echo "mux(EXAMPLE): implement mux_self" >&2
    return 1
}

# Open a sibling pane running MUX_CMD with the MUX_ENV assignments, split from
# MUX_FROM (default: current pane), and print the new pane's handle on stdout.
#   MUX_ENV  : array of K=V strings   MUX_CMD : command + args   MUX_FROM : handle
# Most multiplexers inherit the parent env, so prefixing MUX_CMD with `env
# K=V ...` is the portable way to apply MUX_ENV.
mux_spawn() {
    local pre=()
    if [ ${#MUX_ENV[@]} -gt 0 ]; then
        pre=(env "${MUX_ENV[@]}")
    fi
    # zellij: zellij action new-pane -d down -- "${pre[@]}" "${MUX_CMD[@]}"
    #         then echo the pane name you assigned (zellij prints no id).
    # screen: screen -X screen "${pre[@]}" "${MUX_CMD[@]}"; echo its window id.
    echo "mux(EXAMPLE): implement mux_spawn for: ${pre[*]} ${MUX_CMD[*]}" >&2
    return 1
}

# Grab attention on <handle> and submit TEXT as a single input line. Because
# injecting mid-loop is flaky, submit, wait, and re-submit if it did not take.
# Return immediately — do NOT wait for a reply.
mux_inject() {
    local target="$1" text="$2"
    # zellij: zellij action focus... ; write 27 ; write-chars -- "$text" ; write 13
    # screen: screen -S "$target" -X stuff $'\e' ; stuff "$text"$'\n'
    echo "mux(EXAMPLE): implement mux_inject of '$text' into '$target'" >&2
    return 1
}

# Focus / select <handle>.
mux_focus() {
    # zellij: zellij action focus-pane... "$1"
    # screen: screen -S "$1" -X select "$1"
    return 0
}
