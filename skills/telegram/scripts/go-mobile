#!/usr/bin/env bash
# Run BY an epic owner (inside its own multiplexer pane) to go mobile: spawn a
# dedicated Telegram liaison in a new pane, then return to work. The liaison
# owns the window's topic and relays; the epic owner only appends its replies
# and reports to the channel file.
#
# The multiplexer is pluggable (see scripts/mux): set SIDEBAND_MUX=<backend>
# to run under something other than tmux. Defaults to tmux.
#
# Usage:  go-mobile <window-tag> [liaison-agent-cmd]
#   <window-tag>        e.g. keri-e21
#   [liaison-agent-cmd] command prefix taking one prompt arg; default matches
#                       a Claude epic owner. For Codex use: 'codex exec'
set -euo pipefail

tag="${1:?usage: go-mobile <window-tag> [liaison-agent-cmd]}"
agent="${2:-claude --dangerously-skip-permissions -p}"

here="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
mux="$here/mux"
export SIDEBAND_MUX="${SIDEBAND_MUX:-tmux}"

epic_pane="$("$mux" self)" \
    || { echo "run go-mobile inside your $SIDEBAND_MUX pane" >&2; exit 1; }

state="$HOME/.local/state/sideband/tags/$tag"
from_epic="$state/from-epic"
status_file="$(git rev-parse --show-toplevel 2>/dev/null || pwd)/STATUS.md"

mkdir -p "$state/inbox"
: >> "$from_epic"

# Spawn a liaison pane next to the epic owner and start the loop there.
# Config (including which multiplexer backend to use) travels as pane env.
liaison_pane=$("$mux" spawn --from "$epic_pane" \
    --env "TG_TAG=$tag" \
    --env "EPIC_PANE=$epic_pane" \
    --env "STATUS_FILE=$status_file" \
    --env "FROM_EPIC=$from_epic" \
    --env "LIAISON_AGENT=$agent" \
    --env "TG_AGENT_ENV=${TG_AGENT_ENV:-/code/voice-agent/.env}" \
    --env "SIDEBAND_MUX=$SIDEBAND_MUX" \
    -- "$here/liaison")
"$mux" focus "$epic_pane"

cat <<EOF
Liaison spawned for window '$tag' in pane $liaison_pane.
  - Your channel file: $from_epic
  - Append one line there whenever you finish an instruction, hit a milestone,
    or get blocked — the liaison relays it to Telegram.
  - The liaison pokes THIS pane only for real instructions.
You can go back to work now.
EOF
