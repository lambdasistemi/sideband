#!/usr/bin/env bash
set -euo pipefail

version_or_tag="${1:-}"
if [[ -z "$version_or_tag" ]]; then
  version_or_tag="$(scripts/release/get-cabal-version)"
fi

version="${version_or_tag#refs/tags/}"
version="${version#v}"

found=0
in_section=0

while IFS= read -r line || [[ -n "$line" ]]; do
  if [[ "$line" == "## [$version]"* ]] \
    || [[ "$line" == "## $version" ]] \
    || [[ "$line" == "## $version "* ]]; then
    found=1
    in_section=1
    continue
  fi

  if [[ "$in_section" == "1" && "$line" == "## "* ]]; then
    break
  fi

  if [[ "$in_section" == "1" ]]; then
    printf '%s\n' "$line"
  fi
done <CHANGELOG.md

if [[ "$found" != "1" ]]; then
  exit 1
fi
